  "components": {
    "schemas": {
      "Country": {
        "type": "object",
        "properties": {
          "isoSymbol": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "areaPhoneCode": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "IrrigationMethod": {
        "required": [
          "irrigationMethodName"
        ],
        "type": "object",
        "properties": {
          "isActive": {
            "type": "boolean"
          },
          "irrigationMethodId": {
            "type": "integer",
            "format": "int32"
          },
          "irrigationMethodName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "IrrigationMethodRequest": {
        "required": [
          "irrigationMethodName"
        ],
        "type": "object",
        "properties": {
          "irrigationMethodName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "Name of the irrigation method"
          }
        },
        "additionalProperties": false,
        "description": "Method of irrigation"
      },
      "IrrigationMethodUpdateRequest": {
        "required": [
          "irrigationMethodName"
        ],
        "type": "object",
        "properties": {
          "irrigationMethodName": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string",
            "description": "Name of the irrigation method"
          },
          "isActive": {
            "type": "boolean",
            "description": "Determines whether this option is active for lookup"
          }
        },
        "additionalProperties": false,
        "description": "Method of irrigation"
      },
      "MeasureUnit": {
        "required": [
          "fieldDesc",
          "unitSymbol"
        ],
        "type": "object",
        "properties": {
          "isActive": {
            "type": "boolean"
          },
          "uomId": {
            "type": "integer",
            "format": "int32"
          },
          "fieldDesc": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string"
          },
          "unitSymbol": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string"
          },
          "unitSystem": {
            "$ref": "#/components/schemas/UnitSystem"
          }
        },
        "additionalProperties": false
      },
      "MeasureUnitRequest": {
        "required": [
          "fieldDesc",
          "unitSymbol"
        ],
        "type": "object",
        "properties": {
          "fieldDesc": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string",
            "description": "Name of the field that will have a unit of measure"
          },
          "unitSymbol": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string",
            "description": "Symbol that will be presented in the app, next to the measured value"
          },
          "unitSystem": {
            "$ref": "#/components/schemas/UnitSystem"
          }
        },
        "additionalProperties": false,
        "description": "Meaure unit"
      },
      "MeasureUnitUpdateRequest": {
        "required": [
          "fieldDesc",
          "unitSymbol"
        ],
        "type": "object",
        "properties": {
          "fieldDesc": {
            "maxLength": 150,
            "minLength": 1,
            "type": "string",
            "description": "Name of the field that will have a unit of measure"
          },
          "unitSymbol": {
            "maxLength": 50,
            "minLength": 1,
            "type": "string",
            "description": "Symbol that will be presented in the app, next to the measured value"
          },
          "unitSystem": {
            "$ref": "#/components/schemas/UnitSystem"
          },
          "isActive": {
            "type": "boolean",
            "description": "Determines whether this option is active for lookup"
          }
        },
        "additionalProperties": false,
        "description": "Meaure unit"
      },
      "MergedTimeZoneResponse": {
        "type": "object",
        "properties": {
          "displayName": {
            "type": "string",
            "description": "Gets the general display name that represents the time zone.\r\nReturns: The time zone's general display name.",
            "nullable": true
          },
          "windowsId": {
            "type": "string",
            "description": "Gets the Windows time zone identifier.\r\nReturns: The Windows time zone identifier.",
            "nullable": true
          },
          "ianaId": {
            "type": "string",
            "description": "Gets the IANA time zone identifier.\r\nReturns: The IANA time zone identifier.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Timezone DTO"
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": {}
      },
      "State": {
        "type": "object",
        "properties": {
          "stateIsoCode": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "countryIsoCode": {
            "type": "string",
            "nullable": true
          },
          "type": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "TimeSpan": {
        "type": "object",
        "properties": {
          "ticks": {
            "type": "integer",
            "format": "int64"
          },
          "days": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "hours": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "milliseconds": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "minutes": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "seconds": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "totalDays": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "totalHours": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "totalMilliseconds": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "totalMinutes": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "totalSeconds": {
            "type": "number",
            "format": "double",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "TimeZoneInfo": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "hasIanaId": {
            "type": "boolean",
            "readOnly": true
          },
          "displayName": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "standardName": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "daylightName": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          },
          "baseUtcOffset": {
            "$ref": "#/components/schemas/TimeSpan"
          },
          "supportsDaylightSavingTime": {
            "type": "boolean",
            "readOnly": true
          }
        },
        "additionalProperties": false
      },
      "TzdbZoneLocation": {
        "type": "object",
        "properties": {
          "latitude": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "longitude": {
            "type": "number",
            "format": "double",
            "readOnly": true
          },
          "countryName": {
            "type": "string",
            "nullable": true
          },
          "countryCode": {
            "type": "string",
            "nullable": true
          },
          "zoneId": {
            "type": "string",
            "nullable": true
          },
          "comment": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UnitSystem": {
        "enum": [
          "Metric",
          "Imperial"
        ],
        "type": "string"
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "apiKey",
        "description": "JWT Authorization header using the Bearer scheme. \\r\\n\\r\\n \n                      Enter 'Bearer' [space] and then your token in the text input below.\n                      \\r\\n\\r\\nExample: 'Bearer 12345abcdef'",
        "name": "Authorization",
        "in": "header"
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ]
}